local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local SpeedToggle = false
local JumpToggle = false
local FlyToggle = false
local GhostToggle = false
local BodyVelocity = nil

-- Loop Utama Fisika Karakter
game:GetService("RunService").RenderStepped:Connect(function()
    local Character = LocalPlayer.Character
    if Character then
        -- Fitur Tembus Dinding (Noclip) otomatis aktif saat mode Hantu dinyalakan
        if GhostToggle then
            for _, part in pairs(Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end

        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Humanoid then
            if SpeedToggle then Humanoid.WalkSpeed = 100 end
            if JumpToggle then 
                Humanoid.UseJumpPower = true
                Humanoid.JumpPower = 150 
            end
            
            -- Logika Terbang (Fly)
            if FlyToggle then
                local RootPart = Character:FindFirstChild("HumanoidRootPart") or Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("Torso")
                if RootPart then
                    if not BodyVelocity then
                        BodyVelocity = Instance.new("BodyVelocity")
                        BodyVelocity.MaxForce = Vector3.new(400000, 400000, 400000)
                        BodyVelocity.Parent = RootPart
                    end
                    local Camera = workspace.CurrentCamera
                    BodyVelocity.Velocity = Camera.CFrame.LookVector * 60
                end
            else
                if BodyVelocity then BodyVelocity:Destroy() BodyVelocity = nil end
            end
        end
    end
end)

