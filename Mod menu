-- 3. LOGIKA DAN FUNGSI FITUR

local LocalPlayer = game:GetService("Players").LocalPlayer
local SpeedToggle = false
local JumpToggle = false
local FlyToggle = false
local BodyVelocity = nil

-- Fungsi Loop untuk menjaga Speed dan Jump tetap aktif walau karakter mati/spawn ulang
game:GetService("RunService").RenderStepped:Connect(function()
    local Character = LocalPlayer.Character
    if Character and Character:FindFirstChild("Humanoid") then
        -- Logika Speed
        if SpeedToggle then
            Character.Humanoid.WalkSpeed = 100
        end
        
        -- Logika Jump
        if JumpToggle then
            Character.Humanoid.UseJumpPower = true
            Character.Humanoid.JumpPower = 150
        end
        
        -- Logika Melayang (Fly)
        if FlyToggle then
            local RootPart = Character:FindFirstChild("HumanoidRootPart")
            if RootPart then
                if not BodyVelocity then
                    BodyVelocity = Instance.new("BodyVelocity")
                    BodyVelocity.MaxForce = Vector3.new(400000, 400000, 400000)
                    BodyVelocity.Parent = RootPart
                end
                -- Membuat karakter melayang diam di tempat jika tidak bergerak
                BodyVelocity.Velocity = Character.Humanoid.MoveDirection * 50 + Vector3.new(0, 2, 0)
            end
        else
            if BodyVelocity then
                BodyVelocity:Destroy()
                BodyVelocity = nil
            end
        end
    end
end)

-- Deteksi Klik Tombol Speed
SpeedButton.MouseButton1Click:Connect(function()
    SpeedToggle = not SpeedToggle
    if SpeedToggle then
        SpeedButton.Text = "Speed 100: ON"
        SpeedButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0) -- Hijau
    else
        SpeedButton.Text = "Speed 100: OFF"
        SpeedButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50) -- Abu-abu
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = 16 -- Kembalikan ke normal
        end
    end
end)

-- Deteksi Klik Tombol Jump
JumpButton.MouseButton1Click:Connect(function()
    JumpToggle = not JumpToggle
    if JumpToggle then
        JumpButton.Text = "High Jump: ON"
        JumpButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    else
        JumpButton.Text = "High Jump: OFF"
        JumpButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.JumpPower = 50 -- Kembalikan ke normal
        end
    end
end)

-- Deteksi Klik Tombol Fly
