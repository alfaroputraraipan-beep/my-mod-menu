-- Deteksi Klik Tombol Ghost Mode (Real Anti Mati & Tembus Tembok)
GhostButton.MouseButton1Click:Connect(function()
    GhostToggle = not GhostToggle
    if GhostToggle then
        GhostButton.Text = "Ghost Mode: ON"
        GhostButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        
        -- Eksekusi Trik Hantu: Mematikan koneksi deteksi ke Server
        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChild("Humanoid") then
            local clone = Character.Humanoid:Clone()
            Character.Humanoid:Destroy()
            clone.Parent = Character
            task.wait(0.1)
            
            -- Hidupkan fitur terbang secara otomatis agar tidak jatuh ke bawah peta
            FlyToggle = true
            FlyButton.Text = "Fly: ON"
            FlyButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        end
    else
        GhostButton.Text = "Ghost Mode: OFF"
        GhostButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        -- Untuk menonaktifkan mode hantu, kamu cukup lakukan Reset Character di menu Roblox biasa
    end
end)
