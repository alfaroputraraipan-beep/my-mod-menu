-- Deteksi Klik Tombol God Mode
GodButton.MouseButton1Click:Connect(function()
    GodToggle = not GodToggle
    if GodToggle then
        GodButton.Text = "God Mode: ON"
        GodButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        
        -- Trik memutus script damage lokal dari peta (jika memungkinkan)
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Animate") then
            -- Beberapa tipe kill-brick gagal mendeteksi jika state diubah
            LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        end
    else
        GodButton.Text = "God Mode: OFF"
        GodButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        end
    end
end)
